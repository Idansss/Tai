# Copy this file to `.env` at the repo root and fill in real values. The backend (API, worker,
# admin scripts, and the Prisma seeds) loads that root `.env` automatically. Variables already set
# in the environment always win over the file, and no file is required (CI/production use the real
# environment). The Next.js apps read their own apps/*/.env.local instead.
NODE_ENV=development
API_PORT=4000
# Local Docker Compose defaults. For the shared Supabase database and storage, see the
# "Supabase hosting" section of docs/backend/DEPLOYMENT.md. Two rules matter there:
# connect on port 5432 (session mode) because the API uses interactive transactions, and
# always append ?schema=tai. Never commit a real connection string or access key.
DATABASE_URL=postgresql://tai:local_development_only@localhost:5432/tai_manic?schema=public
REDIS_URL=redis://localhost:6379
# Supabase Storage is S3-compatible, so only these values change; no code change is needed.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=tai-manic-local
S3_ACCESS_KEY=minio
S3_SECRET_KEY=local_development_only
# Required in production; POST raw bytes and return {"status":"CLEAN"|"INFECTED","signature"?:string}
MEDIA_MALWARE_SCAN_URL=
LOG_LEVEL=info
APP_PUBLIC_URL=http://localhost:3000
# Storefront data source. Per-domain composition lives in
# apps/storefront/lib/data/index.ts; only domains with a merged backend honour `api`.
# Left unset (mock) by default on purpose: the catalogue routes are statically generated,
# so `pnpm build` fetches and would fail wherever no API is reachable, CI included.
# DATA_SOURCE=api
# Where the browser reaches the API. Same-origin in production (via a rewrite) keeps the
# tms_session / tms_cart cookies first-party.
NEXT_PUBLIC_API_URL=http://localhost:4000
SMTP_URL=smtp://localhost:1025
EMAIL_FROM=no-reply@taimanic.local
AUTH_TOKEN_PEPPER=local-development-auth-pepper-change-me
AUTH_COOKIE_NAME=tms_session
AUTH_SESSION_TTL_SECONDS=2592000
AUTH_VERIFICATION_TTL_SECONDS=86400
AUTH_RESET_TTL_SECONDS=3600
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5
ADMIN_AUTH_COOKIE_NAME=tms_admin_session
ADMIN_AUTH_SESSION_TTL_SECONDS=28800
ADMIN_MFA_CHALLENGE_TTL_SECONDS=300
ADMIN_MFA_ENCRYPTION_KEY=bG9jYWwtZGV2ZWxvcG1lbnQtbWZhLWtleS0xMjM0NTY
# Payment gateway. 'mock' is development/test only and is rejected in production; 'flutterwave'
# is the real adapter (TMS-B5-002) and requires the FLUTTERWAVE_* credentials below.
PAYMENT_PROVIDER=mock
# HMAC secret the mock provider signs and verifies webhooks with. Replace per deployment.
MOCK_PAYMENT_WEBHOOK_SECRET=local-development-mock-webhook-secret
# Flutterwave (required when PAYMENT_PROVIDER=flutterwave). Amounts settle in naira (major units);
# the adapter converts to/from kobo. FLUTTERWAVE_WEBHOOK_HASH is the dashboard 'verif-hash' secret.
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=
