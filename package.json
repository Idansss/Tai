{
  "name": "tai-manic-studios",
  "version": "0.1.0.0",
  "private": true,
  "description": "Tai Manic Studios art-first commerce platform",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.20.0",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=10.20.0"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13",
      "fast-xml-parser": ">=5.5.6"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rimraf .turbo coverage",
    "dev": "turbo run dev --parallel",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @tms/database db:generate",
    "db:validate": "pnpm --filter @tms/database db:validate",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm db:validate"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "rimraf": "6.1.2",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
