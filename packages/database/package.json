{
  "name": "@tms/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && prisma generate && tsc -p tsconfig.build.json",
    "clean": "rimraf dist generated tsconfig.tsbuildinfo",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed-dev.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed-dev.ts",
    "lint": "eslint src prisma.config.ts prisma/seed.ts prisma/seed-catalogue.ts prisma/seed-dev.ts --max-warnings=0",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "prisma": "7.8.0",
    "tsx": "4.23.1"
  }
}
