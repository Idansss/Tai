  template   GarmentTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variants   GarmentVariant[]

  @@unique([templateId, slug], map: "garment_colours_template_slug_key")
  @@index([templateId, status, position], map: "garment_colours_template_status_position_idx")
  @@map("garment_colours")
}

model GarmentSize {
  id           String                   @id @default(uuid()) @db.Uuid
  templateId   String                   @map("template_id") @db.Uuid
  code         String                   @db.VarChar(32)
  label        String                   @db.VarChar(100)
  position     Int                      @default(0)
  status       ArtworkStatus            @default(DRAFT)
  createdAt    DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(3)
  template     GarmentTemplate          @relation(fields: [templateId], references: [id], onDelete: Cascade)
  measurements GarmentSizeMeasurement[]
  variants     GarmentVariant[]

  @@unique([templateId, code], map: "garment_sizes_template_code_key")
  @@index([templateId, status, position], map: "garment_sizes_template_status_position_idx")
  @@map("garment_sizes")
}

model GarmentSizeMeasurement {
  id      String      @id @default(uuid()) @db.Uuid
  sizeId  String      @map("size_id") @db.Uuid
  key     String      @db.VarChar(64)
  label   String      @db.VarChar(100)
  valueMm Int         @map("value_mm")
  size    GarmentSize @relation(fields: [sizeId], references: [id], onDelete: Cascade)

  @@unique([sizeId, key], map: "garment_size_measurements_size_key_key")
  @@map("garment_size_measurements")
}

model GarmentVariant {
  id         String          @id @default(uuid()) @db.Uuid
  templateId String          @map("template_id") @db.Uuid
  colourId   String          @map("colour_id") @db.Uuid
  sizeId     String          @map("size_id") @db.Uuid
  sku        String          @unique(map: "garment_variants_sku_key") @db.VarChar(80)
  status     ArtworkStatus   @default(DRAFT)
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  template   GarmentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  colour     GarmentColour   @relation(fields: [colourId], references: [id], onDelete: Restrict)
  size       GarmentSize     @relation(fields: [sizeId], references: [id], onDelete: Restrict)

  inventoryItem InventoryItem?
  designConfigurations DesignConfiguration[]
  cartLines            CartLine[]
  orderItems           OrderItem[]

  @@unique([templateId, colourId, sizeId], map: "garment_variants_template_colour_size_key")
  @@index([templateId, status], map: "garment_variants_template_status_idx")
  @@map("garment_variants")
}

model GarmentPlacement {
  id              String                    @id @default(uuid()) @db.Uuid
  templateId      String                    @map("template_id") @db.Uuid
  slug            String                    @db.VarChar(100)
  name            String                    @db.VarChar(100)
  view            GarmentView
  xPermille       Int                       @map("x_permille")
  yPermille       Int                       @map("y_permille")
  widthPermille   Int                       @map("width_permille")
  heightPermille  Int                       @map("height_permille")
  printWidthMm    Int                       @map("print_width_mm")
  printHeightMm   Int                       @map("print_height_mm")
  position        Int                       @default(0)
  status          ArtworkStatus             @default(DRAFT)
  createdAt       DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)
  template        GarmentTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  scalePresets    GarmentScalePreset[]
  compatibilities ArtworkGarmentPlacement[]
  mockupAssets    ArtworkAsset[]

  designConfigurations DesignConfiguration[]
  cartLines            CartLine[]
  orderItems           OrderItem[]

  @@unique([templateId, slug], map: "garment_placements_template_slug_key")
  @@index([templateId, status, position], map: "garment_placements_template_status_position_idx")
  @@map("garment_placements")
}

model GarmentScalePreset {
  id           String           @id @default(uuid()) @db.Uuid
  placementId  String           @map("placement_id") @db.Uuid
  slug         String           @db.VarChar(64)
  name         String           @db.VarChar(100)
  scalePercent Int              @map("scale_percent")
  position     Int              @default(0)
  status       ArtworkStatus    @default(DRAFT)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  placement    GarmentPlacement @relation(fields: [placementId], references: [id], onDelete: Cascade)

  designConfigurations DesignConfiguration[]
  cartLines            CartLine[]
  orderItems           OrderItem[]

  @@unique([placementId, slug], map: "garment_scale_presets_placement_slug_key")
  @@index([placementId, status, position], map: "garment_scale_presets_placement_status_position_idx")
  @@map("garment_scale_presets")
}

model ArtworkGarmentCompatibility {
  id               String                    @id @default(uuid()) @db.Uuid
  artworkVersionId String                    @map("artwork_version_id") @db.Uuid
  templateId       String                    @map("template_id") @db.Uuid
  status           CompatibilityStatus       @default(DRAFT)
  /// Integer minor units (kobo). Required exactly when status is APPROVED. See ADR-015.
  unitPriceMinor   Int?                      @map("unit_price_minor")
  currency         String?                   @db.Char(3)
  createdByUserId  String                    @map("created_by_user_id") @db.Uuid
  approvedByUserId String?                   @map("approved_by_user_id") @db.Uuid
  approvedAt       DateTime?                 @map("approved_at") @db.Timestamptz(3)
  archivedAt       DateTime?                 @map("archived_at") @db.Timestamptz(3)
  createdAt        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(3)
  artworkVersion   ArtworkVersion            @relation(fields: [artworkVersionId], references: [id], onDelete: Restrict)
  template         GarmentTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy        User                      @relation("GarmentCompatibilityCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedBy       User?                     @relation("GarmentCompatibilityApprover", fields: [approvedByUserId], references: [id], onDelete: Restrict)
  placements       ArtworkGarmentPlacement[]

  @@unique([artworkVersionId, templateId], map: "artwork_garment_compatibilities_version_template_key")
  @@index([templateId, status], map: "artwork_garment_compatibilities_template_status_idx")
  @@map("artwork_garment_compatibilities")
}

model ArtworkGarmentPlacement {
  compatibilityId String                      @map("compatibility_id") @db.Uuid
  placementId     String                      @map("placement_id") @db.Uuid
  compatibility   ArtworkGarmentCompatibility @relation(fields: [compatibilityId], references: [id], onDelete: Cascade)
  placement       GarmentPlacement            @relation(fields: [placementId], references: [id], onDelete: Restrict)

  @@id([compatibilityId, placementId])
  @@index([placementId, compatibilityId], map: "artwork_garment_placements_placement_compatibility_idx")
  @@map("artwork_garment_placements")
}

/// Stock is held against the blank garment variant, never against artwork. One row per variant;
/// this row is also the lock target that serialises concurrent reservations for that variant.
model InventoryItem {
  id                String                 @id @default(uuid()) @db.Uuid
  variantId         String                 @unique(map: "inventory_items_variant_id_key") @map("variant_id") @db.Uuid
  onHand            Int                    @default(0) @map("on_hand")
  lowStockThreshold Int                    @default(0) @map("low_stock_threshold")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime               @updatedAt @map("updated_at") @db.Timestamptz(3)
  variant           GarmentVariant         @relation(fields: [variantId], references: [id], onDelete: Cascade)
  movements         InventoryMovement[]
  reservations      InventoryReservation[]

  @@map("inventory_items")
}

/// Append-only ledger. Every change to on-hand stock writes one row and a database trigger
/// rejects UPDATE and DELETE, so stock history can be audited but never rewritten.
model InventoryMovement {
  id              String                @id @default(uuid()) @db.Uuid
  itemId          String                @map("item_id") @db.Uuid
  kind            InventoryMovementKind
  quantityDelta   Int                   @map("quantity_delta")
  /// The resulting on-hand value, captured so the ledger can be replayed without recomputation.
  onHandAfter     Int                   @map("on_hand_after")
  reason          String?               @db.VarChar(500)
  reference       String?               @db.VarChar(200)
  createdByUserId String?               @map("created_by_user_id") @db.Uuid
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  item            InventoryItem         @relation(fields: [itemId], references: [id], onDelete: Restrict)
  createdBy       User?                 @relation("InventoryMovementActor", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([itemId, createdAt], map: "inventory_movements_item_created_at_idx")
  @@map("inventory_movements")
}

/// An expiring hold on stock. Available stock is on-hand minus the sum of ACTIVE reservations
/// that have not expired, so a reservation reduces availability without moving stock.
model InventoryReservation {
  id          String                     @id @default(uuid()) @db.Uuid
  itemId      String                     @map("item_id") @db.Uuid
  quantity    Int
  status      InventoryReservationStatus @default(ACTIVE)
  /// Opaque holder key. TMS-B4-002 carts and TMS-B4-003 checkouts own this value.
  reference   String                     @db.VarChar(200)
  expiresAt   DateTime                   @map("expires_at") @db.Timestamptz(3)
  releasedAt  DateTime?                  @map("released_at") @db.Timestamptz(3)
  committedAt DateTime?                  @map("committed_at") @db.Timestamptz(3)
  createdAt   DateTime                   @default(now()) @map("created_at") @db.Timestamptz(3)
  item        InventoryItem              @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([itemId, status, expiresAt], map: "inventory_reservations_item_status_expires_idx")
  @@index([reference], map: "inventory_reservations_reference_idx")
  @@map("inventory_reservations")
}

model DesignConfiguration {
  id                String             @id @default(uuid()) @db.Uuid
  ownerUserId       String             @map("owner_user_id") @db.Uuid
  artworkVersionId  String             @map("artwork_version_id") @db.Uuid
  garmentVariantId  String             @map("garment_variant_id") @db.Uuid
  placementId       String             @map("placement_id") @db.Uuid
  scalePresetId     String             @map("scale_preset_id") @db.Uuid
  view              GarmentView
  configurationHash String             @map("configuration_hash") @db.Char(64)
  name              String?            @db.VarChar(120)
  visibility        DesignVisibility   @default(PRIVATE)
  shareToken        String?            @unique(map: "design_configurations_share_token_key") @map("share_token") @db.VarChar(64)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  owner             User               @relation("DesignConfigurationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  artworkVersion    ArtworkVersion     @relation(fields: [artworkVersionId], references: [id], onDelete: Restrict)
  garmentVariant    GarmentVariant     @relation(fields: [garmentVariantId], references: [id], onDelete: Restrict)
  placement         GarmentPlacement   @relation(fields: [placementId], references: [id], onDelete: Restrict)
  scalePreset       GarmentScalePreset @relation(fields: [scalePresetId], references: [id], onDelete: Restrict)

  @@unique([ownerUserId, configurationHash], map: "design_configurations_owner_hash_key")
  @@index([ownerUserId, createdAt], map: "design_configurations_owner_created_at_idx")
  @@map("design_configurations")
}

model ArtworkAsset {
  id                 String                @id @default(uuid()) @db.Uuid
  artworkVersionId   String                @map("artwork_version_id") @db.Uuid
  sourceAssetId      String?               @map("source_asset_id") @db.Uuid
  garmentTemplateId  String?               @map("garment_template_id") @db.Uuid
  garmentPlacementId String?               @map("garment_placement_id") @db.Uuid
  kind               MediaAssetKind
  variantKey         String                @map("variant_key") @db.VarChar(160)
  storageKey         String                @unique(map: "artwork_assets_storage_key_key") @map("storage_key") @db.VarChar(500)
  originalFilename   String                @map("original_filename") @db.VarChar(255)
  mimeType           String                @map("mime_type") @db.VarChar(100)
  extension          String                @db.VarChar(16)
  byteSize           Int                   @map("byte_size")
  width              Int
  height             Int
  hasAlpha           Boolean               @default(false) @map("has_alpha")
  checksumSha256     String                @map("checksum_sha256") @db.Char(64)
  dominantHex        String?               @map("dominant_hex") @db.Char(7)
  lowResolution      Boolean               @default(false) @map("low_resolution")
  processingStatus   MediaProcessingStatus @default(QUEUED) @map("processing_status")
  malwareScanStatus  MalwareScanStatus     @map("malware_scan_status")
  approvalStatus     MediaApprovalStatus   @default(NOT_REQUIRED) @map("approval_status")
  failureCode        String?               @map("failure_code") @db.VarChar(100)
  failureMessage     String?               @map("failure_message") @db.VarChar(500)
  rejectionReason    String?               @map("rejection_reason") @db.VarChar(500)
  metadata           Json?                 @db.JsonB
  createdByUserId    String                @map("created_by_user_id") @db.Uuid
  approvedByUserId   String?               @map("approved_by_user_id") @db.Uuid
  approvedAt         DateTime?             @map("approved_at") @db.Timestamptz(3)
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(3)
  artworkVersion     ArtworkVersion        @relation(fields: [artworkVersionId], references: [id], onDelete: Restrict)
  sourceAsset        ArtworkAsset?         @relation("MediaAssetDerivatives", fields: [sourceAssetId], references: [id], onDelete: Restrict)
  derivatives        ArtworkAsset[]        @relation("MediaAssetDerivatives")
  garmentTemplate    GarmentTemplate?      @relation(fields: [garmentTemplateId], references: [id], onDelete: Restrict)
  garmentPlacement   GarmentPlacement?     @relation(fields: [garmentPlacementId], references: [id], onDelete: Restrict)
  createdBy          User                  @relation("MediaAssetCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  approvedBy         User?                 @relation("MediaAssetApprover", fields: [approvedByUserId], references: [id], onDelete: Restrict)
  processingJob      MediaProcessingJob?

  @@unique([artworkVersionId, kind, variantKey], map: "artwork_assets_version_kind_variant_key")
  @@index([artworkVersionId, kind, processingStatus], map: "artwork_assets_version_kind_status_idx")
  @@index([approvalStatus, kind, createdAt], map: "artwork_assets_approval_kind_created_idx")
  @@map("artwork_assets")
}

model MediaProcessingJob {
  id              String         @id @default(uuid()) @db.Uuid
  originalAssetId String         @unique(map: "media_processing_jobs_original_asset_key") @map("original_asset_id") @db.Uuid
  status          MediaJobStatus @default(QUEUED)
  attempts        Int            @default(0)
  maxAttempts     Int            @default(3) @map("max_attempts")
  failureCode     String?        @map("failure_code") @db.VarChar(100)
  failureMessage  String?        @map("failure_message") @db.VarChar(500)
  startedAt       DateTime?      @map("started_at") @db.Timestamptz(3)
  completedAt     DateTime?      @map("completed_at") @db.Timestamptz(3)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  originalAsset   ArtworkAsset   @relation(fields: [originalAssetId], references: [id], onDelete: Restrict)

  @@index([status, createdAt], map: "media_processing_jobs_status_created_idx")
  @@map("media_processing_jobs")
}


/// A cart belongs to exactly one owner: a signed-in customer or an anonymous guest token.
/// Prices are never stored here; they are resolved from the approved pair on every read so a
/// stale cart can never quote a price nobody approved (ADR-015).
model Cart {
  id             String     @id @default(uuid()) @db.Uuid
  userId         String?    @unique(map: "carts_user_id_key") @map("user_id") @db.Uuid
  guestToken     String?    @unique(map: "carts_guest_token_key") @map("guest_token") @db.VarChar(64)
  promotionId    String?    @map("promotion_id") @db.Uuid
  lastActivityAt DateTime   @default(now()) @map("last_activity_at") @db.Timestamptz(3)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(3)
  user           User?      @relation("CartOwner", fields: [userId], references: [id], onDelete: Cascade)
  promotion      Promotion? @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  lines          CartLine[]

  @@index([lastActivityAt], map: "carts_last_activity_idx")
  @@map("carts")
}

/// One approved configuration and a quantity. Identical configurations merge onto one line,
/// keyed by the same tuple hash a saved design uses (ADR-014).
model CartLine {
  id                String             @id @default(uuid()) @db.Uuid
  cartId            String             @map("cart_id") @db.Uuid
  artworkVersionId  String             @map("artwork_version_id") @db.Uuid
  garmentVariantId  String             @map("garment_variant_id") @db.Uuid
  placementId       String             @map("placement_id") @db.Uuid
  scalePresetId     String             @map("scale_preset_id") @db.Uuid
  view              GarmentView
  quantity          Int
  configurationHash String             @map("configuration_hash") @db.Char(64)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  cart              Cart               @relation(fields: [cartId], references: [id], onDelete: Cascade)
  artworkVersion    ArtworkVersion     @relation(fields: [artworkVersionId], references: [id], onDelete: Restrict)
  garmentVariant    GarmentVariant     @relation(fields: [garmentVariantId], references: [id], onDelete: Restrict)
  placement         GarmentPlacement   @relation(fields: [placementId], references: [id], onDelete: Restrict)
  scalePreset       GarmentScalePreset @relation(fields: [scalePresetId], references: [id], onDelete: Restrict)

  @@unique([cartId, configurationHash], map: "cart_lines_cart_hash_key")
  @@index([cartId, createdAt], map: "cart_lines_cart_created_idx")
  @@map("cart_lines")
}

/// A discount code. Money is integer minor units and the discount can never exceed the
/// subtotal it applies to.
model Promotion {
  id              String          @id @default(uuid()) @db.Uuid
  code            String          @unique(map: "promotions_code_key") @db.VarChar(64)
  label           String          @db.VarChar(120)
  kind            PromotionKind
  /// Percent (1-100) for PERCENT_OFF, or minor units for FIXED_AMOUNT.
  value           Int
  currency        String?         @db.Char(3)
  status          PromotionStatus @default(DRAFT)
  startsAt        DateTime?       @map("starts_at") @db.Timestamptz(3)
  endsAt          DateTime?       @map("ends_at") @db.Timestamptz(3)
  minSubtotalMinor Int?           @map("min_subtotal_minor")
  maxDiscountMinor Int?           @map("max_discount_minor")
  createdByUserId String          @map("created_by_user_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy       User            @relation("PromotionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  carts           Cart[]

  @@index([status, startsAt], map: "promotions_status_starts_idx")
  @@map("promotions")
}

/// A placed order. Every money amount is an integer copy taken at placement, never a live
/// reference to the priced compatibility, so a later price change cannot rewrite history
/// (ADR-015, ADR-018). A guest order has no userId and reconciles to an account by verified
/// contact email. Status transitions run through the audited state machine only.
model Order {
  id                 String        @id @default(uuid()) @db.Uuid
  reference          String        @unique(map: "orders_reference_key") @db.VarChar(20)
  userId             String?       @map("user_id") @db.Uuid
  status             OrderStatus   @default(AWAITING_PAYMENT)
  /// Optional caller-supplied replay key. A retried checkout with the same key returns the
  /// same order rather than placing a second one and draining stock twice.
  idempotencyKey     String?       @map("idempotency_key") @db.VarChar(120)
  contactEmail       String        @map("contact_email") @db.VarChar(320)
  normalizedEmail    String        @map("normalized_email") @db.VarChar(320)
  contactName        String        @map("contact_name") @db.VarChar(200)
  contactPhone       String?       @map("contact_phone") @db.VarChar(20)
  addressState       String        @map("address_state") @db.VarChar(100)
  addressCity        String        @map("address_city") @db.VarChar(120)
  addressLine1       String        @map("address_line1") @db.VarChar(200)
  addressLine2       String?       @map("address_line2") @db.VarChar(200)
  addressPostcode    String?       @map("address_postcode") @db.VarChar(20)
  deliveryMethod     DeliveryMethod @map("delivery_method")
  currency           String        @db.Char(3)
  subtotalMinor      Int           @map("subtotal_minor")
  discountMinor      Int           @default(0) @map("discount_minor")
  deliveryMinor      Int           @map("delivery_minor")
  taxMinor           Int           @map("tax_minor")
  totalMinor         Int           @map("total_minor")
  promotionCode      String?       @map("promotion_code") @db.VarChar(64)
  promotionLabel     String?       @map("promotion_label") @db.VarChar(120)
  placedAt           DateTime      @default(now()) @map("placed_at") @db.Timestamptz(3)
  paidAt             DateTime?     @map("paid_at") @db.Timestamptz(3)
  cancelledAt        DateTime?     @map("cancelled_at") @db.Timestamptz(3)
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  user               User?         @relation("OrderCustomer", fields: [userId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  events             OrderEvent[]
  payments           Payment[]

  @@unique([userId, idempotencyKey], map: "orders_user_idempotency_key")
  @@index([userId, placedAt], map: "orders_user_placed_at_idx")
  @@index([normalizedEmail, placedAt], map: "orders_email_placed_at_idx")
  @@index([status, placedAt], map: "orders_status_placed_at_idx")
  @@map("orders")
}

/// An immutable snapshot of one purchased configuration. Price and every descriptive field are
/// copied at placement; the tuple foreign keys are RESTRICT so the source configuration cannot be
/// deleted out from under a historical order. reservationId links the inventory hold taken at
/// checkout so it can be committed on payment or released on failure (ADR-016, ADR-017).
model OrderItem {
  id                String             @id @default(uuid()) @db.Uuid
  orderId           String             @map("order_id") @db.Uuid
  artworkVersionId  String             @map("artwork_version_id") @db.Uuid
  garmentVariantId  String             @map("garment_variant_id") @db.Uuid
  placementId       String             @map("placement_id") @db.Uuid
  scalePresetId     String             @map("scale_preset_id") @db.Uuid
  view              GarmentView
  configurationHash String             @map("configuration_hash") @db.Char(64)
  quantity          Int
  unitPriceMinor    Int                @map("unit_price_minor")
  lineTotalMinor    Int                @map("line_total_minor")
  currency          String             @db.Char(3)
  artworkTitle      String             @map("artwork_title") @db.VarChar(200)
  garmentTitle      String             @map("garment_title") @db.VarChar(200)
  colourName        String             @map("colour_name") @db.VarChar(100)
  sizeLabel         String             @map("size_label") @db.VarChar(100)
  sku               String             @db.VarChar(80)
  /// The inventory reservation held for this line. Opaque, like the reservation reference.
  reservationId     String             @map("reservation_id") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  order             Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artworkVersion    ArtworkVersion     @relation(fields: [artworkVersionId], references: [id], onDelete: Restrict)
  garmentVariant    GarmentVariant     @relation(fields: [garmentVariantId], references: [id], onDelete: Restrict)
  placement         GarmentPlacement   @relation(fields: [placementId], references: [id], onDelete: Restrict)
  scalePreset       GarmentScalePreset @relation(fields: [scalePresetId], references: [id], onDelete: Restrict)

  @@index([orderId], map: "order_items_order_idx")
  @@map("order_items")
}

/// Append-only status history. A database trigger rejects UPDATE and DELETE, so the audit trail
/// of an order's lifecycle can be replayed but never rewritten (mirrors the inventory ledger).
model OrderEvent {
  id            String         @id @default(uuid()) @db.Uuid
  orderId       String         @map("order_id") @db.Uuid
  fromStatus    OrderStatus?   @map("from_status")
  toStatus      OrderStatus    @map("to_status")
  reason        String?        @db.VarChar(500)
  actorType     AuditActorType @default(SYSTEM) @map("actor_type")
  actorUserId   String?        @map("actor_user_id") @db.Uuid
  correlationId String         @map("correlation_id") @db.VarChar(128)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  order         Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt], map: "order_events_order_created_idx")
  @@map("order_events")
}

/// A payment attempt against an order, held behind the provider-neutral PaymentProvider port
/// (ADR-004). The provider reference is the gateway's own identifier; money is integer minor
/// units. Multiple attempts per order are allowed (a failed payment can be retried), matched by
/// the unique provider reference. Success is applied to the order only through the audited state
/// machine (ADR-018).
model Payment {
  id                String         @id @default(uuid()) @db.Uuid
  orderId           String         @map("order_id") @db.Uuid
  provider          String         @db.VarChar(40)
  providerReference String         @unique(map: "payments_provider_reference_key") @map("provider_reference") @db.VarChar(200)
  status            PaymentStatus  @default(PENDING)
  amountMinor       Int            @map("amount_minor")
  currency          String         @db.Char(3)
  refundedMinor     Int            @default(0) @map("refunded_minor")
  redirectUrl       String?        @map("redirect_url") @db.VarChar(2000)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events            PaymentEvent[]

  @@index([orderId, createdAt], map: "payments_order_created_idx")
  @@map("payments")
}

/// Every raw provider event (webhook or reconciliation), stored append-only. The unique
/// (provider, providerEventId) makes replayed webhooks idempotent: a duplicate is a no-op rather
/// than a second state change. A trigger rejects UPDATE and DELETE, so the record of what a
/// provider told us can be replayed but never rewritten.
model PaymentEvent {
  id              String        @id @default(uuid()) @db.Uuid
  paymentId       String        @map("payment_id") @db.Uuid
  provider        String        @db.VarChar(40)
  providerEventId String        @map("provider_event_id") @db.VarChar(200)
  type            String        @db.VarChar(80)
  status          PaymentStatus
  amountMinor     Int?          @map("amount_minor")
  payload         Json?         @db.JsonB
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  payment         Payment       @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@unique([provider, providerEventId], map: "payment_events_provider_event_key")
  @@index([paymentId, createdAt], map: "payment_events_payment_created_idx")
  @@map("payment_events")
}

model EmailVerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique(map: "email_verification_tokens_token_hash_key") @map("token_hash") @db.VarChar(128)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt, expiresAt], map: "email_verification_tokens_user_state_idx")
  @@index([expiresAt], map: "email_verification_tokens_expires_at_idx")
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique(map: "password_reset_tokens_token_hash_key") @map("token_hash") @db.VarChar(128)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(3)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt, expiresAt], map: "password_reset_tokens_user_state_idx")
  @@index([expiresAt], map: "password_reset_tokens_expires_at_idx")
  @@map("password_reset_tokens")
}

model AuditLog {
  id            String         @id @default(uuid()) @db.Uuid
  actorType     AuditActorType @map("actor_type")
  actorUserId   String?        @map("actor_user_id") @db.Uuid
  action        String         @db.VarChar(100)
  resourceType  String         @map("resource_type") @db.VarChar(100)
  resourceId    String?        @map("resource_id") @db.VarChar(100)
  outcome       AuditOutcome
  correlationId String         @map("correlation_id") @db.VarChar(128)
  ipAddressHash String?        @map("ip_address_hash") @db.VarChar(128)
  metadata      Json?          @db.JsonB
  occurredAt    DateTime       @default(now()) @map("occurred_at") @db.Timestamptz(3)
  actor         User?          @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, occurredAt], map: "audit_logs_actor_occurred_at_idx")
  @@index([resourceType, resourceId, occurredAt], map: "audit_logs_resource_occurred_at_idx")
  @@index([correlationId], map: "audit_logs_correlation_id_idx")
  @@index([occurredAt], map: "audit_logs_occurred_at_idx")
  @@map("audit_logs")
}
