generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DISABLED
  DELETED
}

enum AdminProfileStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED
}

enum AuditActorType {
  USER
  SYSTEM
  INTEGRATION
}

enum AuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum SessionKind {
  CUSTOMER
  ADMIN
}

enum AuthAssuranceLevel {
  PASSWORD
  MFA
}

enum AdminMfaFactorStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum AdminAuthChallengePurpose {
  ENROLL_TOTP
  VERIFY_TOTP
}

enum ArtworkStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArtworkVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TagKind {
  GENERAL
  THEME
  MOOD
  COLOUR_FAMILY
}

enum StoryBlockType {
  TEXT
  IMAGE
  QUOTE
  EMBED
}

enum GarmentType {
  CLASSIC_TSHIRT
  OVERSIZED_TSHIRT
  LONG_SLEEVE
  HOODIE
  SWEATSHIRT
  TOTE_BAG
  CAP
  ART_PRINT
}

enum GarmentView {
  FRONT
  BACK
  LEFT
  RIGHT
}

enum CompatibilityStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

enum PromotionKind {
  PERCENT_OFF
  FIXED_AMOUNT
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  DISABLED
}

/// The full order lifecycle. TMS-B4-003 drives the checkout-and-payment portion; production,
/// dispatch, and returns transitions belong to later operations tasks against the same machine.
enum OrderStatus {
  DRAFT
  AWAITING_PAYMENT
  PAYMENT_PROCESSING
  PAID
  PRODUCTION_QUEUED
  PRINTING
  QUALITY_CHECK
  READY_FOR_DISPATCH
  SHIPMENT_BOOKED
  SHIPPED
  DELIVERED
  COMPLETED
  PAYMENT_FAILED
  PAYMENT_CANCELLED
  CANCEL_REQUESTED
  CANCELLED
  REFUND_PENDING
  PARTIALLY_REFUNDED
  REFUNDED
  DELIVERY_EXCEPTION
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_IN_TRANSIT
  RETURNED
}

enum DeliveryMethod {
  STANDARD
  EXPRESS
}

/// Payment lifecycle, mirroring the shared PaymentStatus contract. Provider-neutral: the same
/// states describe the mock provider and any real gateway added behind the PaymentProvider port.
enum PaymentStatus {
  CREATED
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REVERSED
  PARTIALLY_REFUNDED
  REFUNDED
  DISPUTED
}

enum InventoryMovementKind {
  RECEIPT
  ADJUSTMENT
  SALE
  RETURN
  DAMAGE
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  COMMITTED
  EXPIRED
}

enum DesignVisibility {
  PRIVATE
  UNLISTED
}

enum MediaAssetKind {
  ORIGINAL
  WEB_DERIVATIVE
  THUMBNAIL
  MOCKUP
}

enum MediaProcessingStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
}

enum MalwareScanStatus {
  CLEAN
  INFECTED
  ERROR
}

enum MediaApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum MediaJobStatus {
  QUEUED
  PROCESSING
  SUCCEEDED
  FAILED
}

model User {
  id                             String                        @id @default(uuid()) @db.Uuid
  email                          String                        @db.VarChar(320)
  normalizedEmail                String                        @unique(map: "users_normalized_email_key") @map("normalized_email") @db.VarChar(320)
  passwordHash                   String?                       @map("password_hash") @db.VarChar(255)
  status                         UserStatus                    @default(PENDING_VERIFICATION)
  emailVerifiedAt                DateTime?                     @map("email_verified_at") @db.Timestamptz(3)
  lastLoginAt                    DateTime?                     @map("last_login_at") @db.Timestamptz(3)
  createdAt                      DateTime                      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                      DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt                      DateTime?                     @map("deleted_at") @db.Timestamptz(3)
  customerProfile                CustomerProfile?
  adminProfile                   AdminProfile?
  sessions                       Session[]
  verificationTokens             EmailVerificationToken[]
  passwordResetTokens            PasswordResetToken[]
  roleAssignments                UserRole[]                    @relation("UserRoleUser")
  roleAssignmentsCreated         UserRole[]                    @relation("UserRoleAssignedBy")
  auditLogs                      AuditLog[]                    @relation("AuditActor")
  adminMfaFactor                 AdminMfaFactor?
  adminAuthChallenges            AdminAuthChallenge[]
  artworksCreated                Artwork[]                     @relation("ArtworkCreator")
  artworkVersionsCreated         ArtworkVersion[]              @relation("ArtworkVersionCreator")
  collectionsCreated             Collection[]                  @relation("CollectionCreator")
  dropsCreated                   Drop[]                        @relation("DropCreator")
  storiesCreated                 Story[]                       @relation("StoryCreator")
  garmentTemplatesCreated        GarmentTemplate[]             @relation("GarmentTemplateCreator")
  garmentCompatibilitiesCreated  ArtworkGarmentCompatibility[] @relation("GarmentCompatibilityCreator")
  garmentCompatibilitiesApproved ArtworkGarmentCompatibility[] @relation("GarmentCompatibilityApprover")
  inventoryMovements             InventoryMovement[]           @relation("InventoryMovementActor")
  cart                           Cart?                         @relation("CartOwner")
  orders                         Order[]                       @relation("OrderCustomer")
  promotionsCreated              Promotion[]                   @relation("PromotionCreator")
  designConfigurations           DesignConfiguration[]         @relation("DesignConfigurationOwner")
  mediaAssetsCreated             ArtworkAsset[]                @relation("MediaAssetCreator")
  mediaAssetsApproved            ArtworkAsset[]                @relation("MediaAssetApprover")

  @@index([status, deletedAt], map: "users_status_deleted_at_idx")
  @@index([createdAt], map: "users_created_at_idx")
  @@map("users")
}

model CustomerProfile {
  userId      String   @id @map("user_id") @db.Uuid
  displayName String?  @map("display_name") @db.VarChar(100)
  firstName   String?  @map("first_name") @db.VarChar(100)
  lastName    String?  @map("last_name") @db.VarChar(100)
  phoneE164   String?  @unique(map: "customer_profiles_phone_e164_key") @map("phone_e164") @db.VarChar(16)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("customer_profiles")
}

model AdminProfile {
  userId        String             @id @map("user_id") @db.Uuid
  displayName   String             @map("display_name") @db.VarChar(100)
  status        AdminProfileStatus @default(INVITED)
  mfaRequired   Boolean            @default(true) @map("mfa_required")
  mfaEnrolledAt DateTime?          @map("mfa_enrolled_at") @db.Timestamptz(3)
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status], map: "admin_profiles_status_idx")
  @@map("admin_profiles")
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  code            String           @unique(map: "roles_code_key") @db.VarChar(64)
  name            String           @db.VarChar(100)
  description     String?          @db.VarChar(500)
  isSystem        Boolean          @default(true) @map("is_system")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(3)
  permissions     RolePermission[]
  userAssignments UserRole[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique(map: "permissions_code_key") @db.VarChar(100)
  resource    String           @db.VarChar(64)
  action      String           @db.VarChar(64)
  description String?          @db.VarChar(500)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(3)
  roles       RolePermission[]

  @@unique([resource, action], map: "permissions_resource_action_key")
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  grantedAt    DateTime   @default(now()) @map("granted_at") @db.Timestamptz(3)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId], map: "role_permissions_permission_id_idx")
  @@map("role_permissions")
}

model UserRole {
  userId           String    @map("user_id") @db.Uuid
  roleId           String    @map("role_id") @db.Uuid
  assignedByUserId String?   @map("assigned_by_user_id") @db.Uuid
  assignedAt       DateTime  @default(now()) @map("assigned_at") @db.Timestamptz(3)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz(3)
  user             User      @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  role             Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedBy       User?     @relation("UserRoleAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@index([roleId], map: "user_roles_role_id_idx")
  @@index([assignedByUserId], map: "user_roles_assigned_by_user_id_idx")
  @@index([expiresAt], map: "user_roles_expires_at_idx")
  @@map("user_roles")
}

model Session {
  id               String             @id @default(uuid()) @db.Uuid
  userId           String             @map("user_id") @db.Uuid
  tokenHash        String             @unique(map: "sessions_token_hash_key") @map("token_hash") @db.VarChar(128)
  kind             SessionKind        @default(CUSTOMER)
  assuranceLevel   AuthAssuranceLevel @default(PASSWORD) @map("assurance_level")
  mfaVerifiedAt    DateTime?          @map("mfa_verified_at") @db.Timestamptz(3)
  expiresAt        DateTime           @map("expires_at") @db.Timestamptz(3)
  lastSeenAt       DateTime           @default(now()) @map("last_seen_at") @db.Timestamptz(3)
  revokedAt        DateTime?          @map("revoked_at") @db.Timestamptz(3)
  revocationReason String?            @map("revocation_reason") @db.VarChar(200)
  ipAddressHash    String?            @map("ip_address_hash") @db.VarChar(128)
  userAgent        String?            @map("user_agent") @db.VarChar(500)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt], map: "sessions_user_revoked_expires_idx")
  @@index([userId, kind, revokedAt, expiresAt], map: "sessions_user_kind_state_idx")
  @@index([expiresAt], map: "sessions_expires_at_idx")
  @@map("sessions")
}

model AdminMfaFactor {
  userId           String               @id @map("user_id") @db.Uuid
  status           AdminMfaFactorStatus @default(PENDING)
  secretCiphertext String               @map("secret_ciphertext") @db.VarChar(1000)
  lastUsedTimeStep BigInt?              @map("last_used_time_step")
  verifiedAt       DateTime?            @map("verified_at") @db.Timestamptz(3)
  revokedAt        DateTime?            @map("revoked_at") @db.Timestamptz(3)
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(3)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status], map: "admin_mfa_factors_status_idx")
  @@map("admin_mfa_factors")
}

model AdminAuthChallenge {
  id                String                    @id @default(uuid()) @db.Uuid
  userId            String                    @map("user_id") @db.Uuid
  tokenHash         String                    @unique(map: "admin_auth_challenges_token_hash_key") @map("token_hash") @db.VarChar(128)
  purpose           AdminAuthChallengePurpose
  expiresAt         DateTime                  @map("expires_at") @db.Timestamptz(3)
  consumedAt        DateTime?                 @map("consumed_at") @db.Timestamptz(3)
  attemptsRemaining Int                       @default(5) @map("attempts_remaining")
  createdAt         DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  user              User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt, expiresAt], map: "admin_auth_challenges_user_state_idx")
  @@index([expiresAt], map: "admin_auth_challenges_expires_at_idx")
  @@map("admin_auth_challenges")
}

model Artwork {
  id              String              @id @default(uuid()) @db.Uuid
  slug            String              @unique(map: "artworks_slug_key") @db.VarChar(160)
  status          ArtworkStatus       @default(DRAFT)
  createdByUserId String              @map("created_by_user_id") @db.Uuid
  publishedAt     DateTime?           @map("published_at") @db.Timestamptz(3)
  archivedAt      DateTime?           @map("archived_at") @db.Timestamptz(3)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy       User                @relation("ArtworkCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  versions        ArtworkVersion[]
  tags            ArtworkTag[]
  collections     CollectionArtwork[]
  drops           DropArtwork[]
  editions        Edition[]
  stories         Story[]

  @@index([status, createdAt], map: "artworks_status_created_at_idx")
  @@index([createdByUserId], map: "artworks_created_by_user_id_idx")
  @@map("artworks")
}

model ArtworkVersion {
  id                     String                        @id @default(uuid()) @db.Uuid
  artworkId              String                        @map("artwork_id") @db.Uuid
  versionNumber          Int                           @map("version_number")
  status                 ArtworkVersionStatus          @default(DRAFT)
  title                  String                        @db.VarChar(200)
  shortStory             String?                       @map("short_story") @db.VarChar(500)
  story                  String?                       @db.Text
  inspiration            String?                       @db.Text
  metadata               Json                          @default("{}") @db.JsonB
  createdByUserId        String                        @map("created_by_user_id") @db.Uuid
  publishedAt            DateTime?                     @map("published_at") @db.Timestamptz(3)
  archivedAt             DateTime?                     @map("archived_at") @db.Timestamptz(3)
  createdAt              DateTime                      @default(now()) @map("created_at") @db.Timestamptz(3)
  artwork                Artwork                       @relation(fields: [artworkId], references: [id], onDelete: Restrict)
  createdBy              User                          @relation("ArtworkVersionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  garmentCompatibilities ArtworkGarmentCompatibility[]
  designConfigurations   DesignConfiguration[]
  mediaAssets            ArtworkAsset[]
  cartLines              CartLine[]
  orderItems             OrderItem[]

  @@unique([artworkId, versionNumber], map: "artwork_versions_artwork_version_key")
  @@index([artworkId, status, versionNumber], map: "artwork_versions_artwork_status_version_idx")
  @@index([status, publishedAt], map: "artwork_versions_status_published_at_idx")
  @@index([createdByUserId], map: "artwork_versions_created_by_user_id_idx")
  @@map("artwork_versions")
}

model Tag {
  id        String       @id @default(uuid()) @db.Uuid
  slug      String       @unique(map: "tags_slug_key") @db.VarChar(100)
  name      String       @db.VarChar(100)
  kind      TagKind      @default(GENERAL)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(3)
  artworks  ArtworkTag[]

  @@index([kind, name], map: "tags_kind_name_idx")
  @@map("tags")
}

model ArtworkTag {
  artworkId String   @map("artwork_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  artwork   Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([artworkId, tagId])
  @@index([tagId, artworkId], map: "artwork_tags_tag_artwork_idx")
  @@map("artwork_tags")
}

model Collection {
  id              String              @id @default(uuid()) @db.Uuid
  slug            String              @unique(map: "collections_slug_key") @db.VarChar(160)
  title           String              @db.VarChar(200)
  description     String?             @db.Text
  status          ArtworkStatus       @default(DRAFT)
  createdByUserId String              @map("created_by_user_id") @db.Uuid
  publishedAt     DateTime?           @map("published_at") @db.Timestamptz(3)
  archivedAt      DateTime?           @map("archived_at") @db.Timestamptz(3)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy       User                @relation("CollectionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  artworks        CollectionArtwork[]
  stories         Story[]

  @@index([status, publishedAt], map: "collections_status_published_at_idx")
  @@map("collections")
}

model CollectionArtwork {
  collectionId String     @map("collection_id") @db.Uuid
  artworkId    String     @map("artwork_id") @db.Uuid
  position     Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  artwork      Artwork    @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@id([collectionId, artworkId])
  @@index([artworkId, collectionId], map: "collection_artworks_artwork_collection_idx")
  @@index([collectionId, position], map: "collection_artworks_collection_position_idx")
  @@map("collection_artworks")
}

model Drop {
  id              String        @id @default(uuid()) @db.Uuid
  slug            String        @unique(map: "drops_slug_key") @db.VarChar(160)
  title           String        @db.VarChar(200)
  description     String?       @db.Text
  status          ArtworkStatus @default(DRAFT)
  startsAt        DateTime?     @map("starts_at") @db.Timestamptz(3)
  endsAt          DateTime?     @map("ends_at") @db.Timestamptz(3)
  createdByUserId String        @map("created_by_user_id") @db.Uuid
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz(3)
  archivedAt      DateTime?     @map("archived_at") @db.Timestamptz(3)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy       User          @relation("DropCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  artworks        DropArtwork[]

  @@index([status, startsAt], map: "drops_status_starts_at_idx")
  @@map("drops")
}

model DropArtwork {
  dropId    String   @map("drop_id") @db.Uuid
  artworkId String   @map("artwork_id") @db.Uuid
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  drop      Drop     @relation(fields: [dropId], references: [id], onDelete: Cascade)
  artwork   Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@id([dropId, artworkId])
  @@index([artworkId, dropId], map: "drop_artworks_artwork_drop_idx")
  @@index([dropId, position], map: "drop_artworks_drop_position_idx")
  @@map("drop_artworks")
}

model Edition {
  id            String        @id @default(uuid()) @db.Uuid
  artworkId     String        @map("artwork_id") @db.Uuid
  name          String        @db.VarChar(120)
  totalQuantity Int?          @map("total_quantity")
  numbered      Boolean       @default(false)
  status        ArtworkStatus @default(DRAFT)
  releasedAt    DateTime?     @map("released_at") @db.Timestamptz(3)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  artwork       Artwork       @relation(fields: [artworkId], references: [id], onDelete: Restrict)

  @@unique([artworkId, name], map: "editions_artwork_name_key")
  @@index([status, releasedAt], map: "editions_status_released_at_idx")
  @@map("editions")
}

model Story {
  id              String        @id @default(uuid()) @db.Uuid
  slug            String        @unique(map: "stories_slug_key") @db.VarChar(160)
  title           String        @db.VarChar(200)
  excerpt         String?       @db.VarChar(500)
  status          ArtworkStatus @default(DRAFT)
  artworkId       String?       @map("artwork_id") @db.Uuid
  collectionId    String?       @map("collection_id") @db.Uuid
  createdByUserId String        @map("created_by_user_id") @db.Uuid
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz(3)
  archivedAt      DateTime?     @map("archived_at") @db.Timestamptz(3)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(3)
  artwork         Artwork?      @relation(fields: [artworkId], references: [id], onDelete: Restrict)
  collection      Collection?   @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  createdBy       User          @relation("StoryCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  blocks          StoryBlock[]

  @@index([status, publishedAt], map: "stories_status_published_at_idx")
  @@index([artworkId], map: "stories_artwork_id_idx")
  @@index([collectionId], map: "stories_collection_id_idx")
  @@map("stories")
}

model StoryBlock {
  id        String         @id @default(uuid()) @db.Uuid
  storyId   String         @map("story_id") @db.Uuid
  position  Int
  type      StoryBlockType
  content   Json           @db.JsonB
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  story     Story          @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, position], map: "story_blocks_story_position_key")
  @@map("story_blocks")
}

model GarmentTemplate {
  id              String                        @id @default(uuid()) @db.Uuid
  slug            String                        @unique(map: "garment_templates_slug_key") @db.VarChar(160)
  title           String                        @db.VarChar(200)
  description     String?                       @db.Text
  type            GarmentType
  fabric          String?                       @db.VarChar(500)
  fit             String?                       @db.VarChar(500)
  care            String?                       @db.Text
  status          ArtworkStatus                 @default(DRAFT)
  createdByUserId String                        @map("created_by_user_id") @db.Uuid
  publishedAt     DateTime?                     @map("published_at") @db.Timestamptz(3)
  archivedAt      DateTime?                     @map("archived_at") @db.Timestamptz(3)
  createdAt       DateTime                      @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(3)
  createdBy       User                          @relation("GarmentTemplateCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  colours         GarmentColour[]
  sizes           GarmentSize[]
  variants        GarmentVariant[]
  placements      GarmentPlacement[]
  compatibilities ArtworkGarmentCompatibility[]
  mockupAssets    ArtworkAsset[]

  @@index([status, createdAt], map: "garment_templates_status_created_at_idx")
  @@map("garment_templates")
}

model GarmentColour {
